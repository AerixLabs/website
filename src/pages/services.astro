---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ServiceList from "@/components/widgets/ServiceList.astro";
import Content from "@/components/widgets/Content.astro";
import Content2 from "@/components/widgets/Content2.astro";
import webDevImg from "@/assets/images/services/web-dev.webp";
import seoImg from "@/assets/images/services/seo.webp";
import consultingImg from "@/assets/images/services/consulting.webp";

const services = [
  {
    title: "Web Development",
    description:
      "High-performance, scalable web solutions built for business growth.",
    icon: "lucide:globe",
  },
  {
    title: "Mobile Apps",
    description:
      "Custom native and cross-platform applications for iOS and Android.",
    icon: "lucide:smartphone",
  },
  {
    title: "Cloud Solutions",
    description:
      "Robust infrastructure and cloud-native application development.",
    icon: "lucide:cloud",
  },
];
const metadata = {
  title: "Our Services — Aerix Labs",
  description:
    "Explore our professional services including web development, mobile app creation, and strategic technology consulting.",
};
---

<BaseLayout {metadata}>
  <Content
    tagline="Services"
    title="Tailored Solutions for Your Digital Success"
    description={[
      "Aerix Labs provides comprehensive software development services designed to maximize your digital potential and drive business impact.",
    ]}
  />
  <ServiceList services={services} classes={{ container: "pt-0 md:pt-0" }} />

  <Content
    tagline="Core Expertise"
    title="Custom Web & Mobile Development"
    description={[
      "We build more than just websites. We create powerful digital experiences that engage users and deliver measurable results.",
    ]}
    classes={{ container: "pb-0 md:pb-0" }}
  />

  <Content2
    items={[
      {
        title: "Enterprise Web Applications",
        description:
          "Complex, data-driven platforms designed to streamline your business operations.",
      },
      {
        title: "E-commerce Solutions",
        description:
          "High-converting online stores built with a focus on speed, security, and user experience.",
      },
    ]}
    image={webDevImg}
    imageAlt="Professional Web Development"
    classes={{ container: "pt-0 md:pt-0" }}
  >
    <Fragment>
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2">
        Full-Stack Web Development
      </h3>
      Our team leverages modern frameworks like React and Astro to build lightning-fast
      web experiences that scale with your business.
    </Fragment>
  </Content2>

  <Content2
    isReversed={true}
    items={[
      {
        title: "Native & Hybrid Apps",
        description:
          "Seamless performance across all platforms using the latest mobile development technologies.",
      },
      {
        title: "UI/UX Design",
        description:
          "Intuitive and engaging mobile interfaces designed for maximum user retention.",
      },
    ]}
    image={seoImg}
    imageAlt="Mobile App Development"
  >
    <Fragment>
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2">
        Mobile Application Excellence
      </h3>
      We transform your ideas into powerful mobile applications, ensuring your brand
      is always at your customers' fingertips.
    </Fragment>
  </Content2>

  <Content2
    items={[
      {
        title: "Digital Transformation",
        description:
          "Guiding you through the adoption of new technologies to modernize your business.",
      },
      {
        title: "Architectural Planning",
        description:
          "Designing robust, secure, and scalable systems prepared for future expansion.",
      },
    ]}
    image={consultingImg}
    imageAlt="Strategic Technology Consulting"
  >
    <Fragment>
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2">
        Strategic IT Consulting
      </h3>
      We partner with you to make critical technology decisions, ensuring your infrastructure
      is built to support your long-term goals.
    </Fragment>
  </Content2>
</BaseLayout>
