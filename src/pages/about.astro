---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getImage } from "astro:assets";
import Content2 from "@/components/widgets/Content2.astro";
import Values from "@/components/widgets/Values.astro";
import aboutImage from "@/assets/images/about-office.webp";

const metadata = {
  title: "About Aerix Labs",
  description:
    "Learn more about our vision, values, and the team at Aerix Labs.",
};

const values = [
  {
    title: "Innovation",
    description:
      "We constantly explore new technologies and methodologies to deliver cutting-edge solutions.",
  },
  {
    title: "Commitment",
    description:
      "We are dedicated to our clients' success, treating every project as our own.",
  },
  {
    title: "Quality",
    description:
      "Our focus on high-performance architecture ensures robust and reliable software.",
  },
  {
    title: "Transparency",
    description:
      "We maintain open and honest communication throughout the entire development lifecycle.",
  },
  {
    title: "Integrity",
    description:
      "Ethical practices and honesty are the foundation of our professional relationships.",
  },
  {
    title: "Excellence",
    description:
      "We strive for perfection in every line of code and every pixel designed.",
  },
];

const optimizedImage = await getImage({
  src: aboutImage,
  format: "webp",
});
---

<BaseLayout {metadata}>
  <link slot="head" rel="preload" href={optimizedImage.src} as="image" />
  <Content2
    title="Our Vision"
    description={[
      "At Aerix Labs, our vision is to lead the digital transformation by providing businesses with high-performance software solutions. We believe that technology should be an enabler, not a barrier, to growth.",
      "We specialize in building modern websites and mobile applications that are not only visually stunning but also technically superior in terms of speed, security, and scalability.",
    ]}
    tagline="About Us"
    image={aboutImage}
    imageAlt="Aerix Labs Team and Innovation"
    actions={[
      {
        text: "Contact Us",
        href: "/contact",
        variant: "primary",
        icon: "lucide:mail",
      },
      {
        text: "View Details",
        href: "#",
        variant: "secondary",
        icon: "lucide:arrow-right",
      },
    ]}
  />
  <Values
    items={values}
    columns={3}
    tagline="Our Values"
    title="What Defines Us"
    subtitle="Principles that guide our daily work"
  />
</BaseLayout>
