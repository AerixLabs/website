---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/config/site";
import Hero from "@/components/widgets/Hero.astro";
import Features from "@/components/widgets/Features.astro";
import devImg from "@/assets/images/dev_balanced.png";
import openSourceImg from "@/assets/images/open-source.png";
import Content2 from "@/components/widgets/Content2.astro";
const metadata = {
  title: `${siteConfig.name} — Software Development Platform`,
  description:
    "Leading software development platform specialized in high-performance website and app development. We build the future of digital solutions.",
  ignoreTitleTemplate: true,
};
---

<BaseLayout {metadata}>
  <Hero
    title={`Innovating the Digital <br class="hidden md:block" /> <span class="bg-linear-to-r from-blue-400 via-purple-400 to-pink-400 bg-clip-text text-transparent">Landscape</span>`}
    tagline="Software Development Platform"
    description="Specialized in building high-performance websites and mobile applications tailored to your business needs."
    actions={[
      {
        text: "Our Services",
        href: "/services",
        variant: "primary",
        icon: "lucide:arrow-right",
      },
      {
        text: "Contact Us",
        href: "/contact",
        variant: "secondary",
        icon: "lucide:mail",
        ariaLabel: "Get in touch with our team",
      },
    ]}
  />
  <Features
    tagline="Core Expertise"
    title="What We Do"
    subtitle="Comprehensive digital solutions designed for scalability and impact."
    features={[
      {
        title: "Web Development",
        description:
          "High-performance, scalable web solutions built with the latest technologies for business growth.",
        icon: "lucide:globe",
        iconClass: "bg-blue-500/10 text-blue-400",
      },
      {
        title: "Mobile Apps",
        description:
          "Custom native and cross-platform mobile applications for iOS and Android.",
        icon: "lucide:smartphone",
        iconClass: "bg-purple-500/10 text-purple-400",
      },
      {
        title: "Cloud Solutions",
        description:
          "Robust infrastructure and cloud-native application development for future-proof scalability.",
        icon: "lucide:cloud",
        iconClass: "bg-pink-500/10 text-pink-400",
      },
    ]}
  />
  <Content2
    items={[
      {
        title: "Modern Architecture",
        description:
          "We use cutting-edge frameworks and patterns to ensure your software is future-proof.",
        icon: "lucide:layers",
        iconClass: "bg-blue-500/10 text-blue-400",
      },
      {
        title: "User-Centric Design",
        description:
          "Every pixel is placed with purpose, ensuring intuitive and engaging interfaces.",
        icon: "lucide:mouse-pointer-2",
        iconClass: "bg-purple-500/10 text-purple-400",
      },
      {
        title: "Scalable Infrastructure",
        description:
          "Our solutions are built to grow with your business, handling increased load effortlessly.",
        icon: "lucide:trending-up",
        iconClass: "bg-pink-500/10 text-pink-400",
      },
    ]}
    image={devImg}
    imageAlt="Software Development Excellence"
  >
    <Fragment>
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2">
        Software Excellence
      </h3>
      We deliver robust and scalable software solutions that drive business growth
      and user satisfaction.
    </Fragment>
  </Content2>
  <Content2
    items={[
      {
        title: "Full-Stack Expertise",
        description:
          "Comprehensive development from front-end interfaces to complex back-end systems.",
        icon: "lucide:code-2",
        iconClass: "bg-indigo-500/10 text-indigo-400",
      },
      {
        title: "Security First",
        description:
          "Implementing industry-standard security practices to protect your data and users.",
        icon: "lucide:shield-check",
        iconClass: "bg-orange-500/10 text-orange-400",
      },
      {
        title: "Continuous Delivery",
        description:
          "Agile processes that ensure frequent updates and transparent communication throughout the project.",
        icon: "lucide:git-pull-request",
        iconClass: "bg-teal-500/10 text-teal-400",
      },
    ]}
    image={openSourceImg}
    imageAlt="Quality and Partnership"
    isReversed={true}
  >
    <Fragment>
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2">
        Your Partner in Innovation
      </h3>
      At Aerix Labs, we don't just build software; we build long-term partnerships
      aimed at achieving your digital goals.
    </Fragment>
  </Content2>
</BaseLayout>
